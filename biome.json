{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error",
        "noUnknownAtRules": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.next",
      "!**/dist",
      "!**/drizzle",
      "!**/packages/sdk/dist",
      "!**/test-results",
      "!**/playwright-report",
      "!**/*.config.js",
      "!**/postcss.config.js",
      "!**/coverage",
      "!**/.omc",
      "!**/.omx",
      "!**/.current-feature.json",
      "!**/tests/e2e/.auth",
      "!**/drizzle",
      "!**/*.d.ts",
      "!**/public",
      "!**/private",
      "!**/ralph-hardening",
      "!**/target-docs"
    ]
  }
}
