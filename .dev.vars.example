# Local secrets for `wrangler dev` — copy to `.dev.vars` (gitignored) and fill in.
# In production these are set as Worker Secrets via `wrangler secret put NAME`
# (or Cloudflare Secrets Store), never committed.
DATABASE_URL=
DB_PASSWORD=
BETTER_AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
OPENAI_API_KEY=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
GITHUB_APP_PRIVATE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
